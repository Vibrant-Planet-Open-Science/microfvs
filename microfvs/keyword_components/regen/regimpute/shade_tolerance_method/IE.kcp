** Subalpine Fir
IF        10
SpMcDBH(11,ALL,0,1.0,999,1.0,999,0) LE BSDIMAX*0.75 AND SpMcDBH(1,AF,0,5,999,10,999,0) GT 0.001 AND REGTRIG EQ 1
Then
Estab
Natural            1    Parms(AF, ST4MRA, 100, REGENAGE, 0, 0)
End
Compute            1
RegTotal = Regtotal + ST4MRA
End
EndIf

** Engelmann Spruce
IF        10
SpMcDBH(11,ALL,0,1.0,999,1.0,999,0) LE BSDIMAX*0.75 AND SpMcDBH(1,ES,0,5,999,10,999,0) GT 0.001 AND REGTRIG EQ 1
Then
Estab
Natural            1    Parms(ES, ST4MRA, 100, REGENAGE, 0, 0)
End
Compute            1
RegTotal = Regtotal + ST4MRA
End
EndIf

** Grand Fir
IF        10
SpMcDBH(11,ALL,0,1.0,999,1.0,999,0) LE BSDIMAX*0.75 AND SpMcDBH(1,GF,0,5,999,10,999,0) GT 0.001 AND REGTRIG EQ 1
Then
Estab
Natural            1    Parms(GF, ST4MRA, 100, REGENAGE, 0, 0)
End
Compute            1
RegTotal = Regtotal + ST4MRA
End
EndIf

** Mountain Hemlock
IF        10
SpMcDBH(11,ALL,0,1.0,999,1.0,999,0) LE BSDIMAX*0.75 AND SpMcDBH(1,MH,0,5,999,10,999,0) GT 0.001 AND REGTRIG EQ 1
Then
Estab
Natural            1    Parms(MH, ST4MRA, 100, REGENAGE, 0, 0)
End
Compute            1
RegTotal = Regtotal + ST4MRA
End
EndIf

** Western Redcedar
IF        10
SpMcDBH(11,ALL,0,1.0,999,1.0,999,0) LE BSDIMAX*0.75 AND SpMcDBH(1,RC,0,5,999,10,999,0) GT 0.001 AND REGTRIG EQ 1
Then
Estab
Natural            1    Parms(RC, ST4MRA, 100, REGENAGE, 0, 0)
End
Compute            1
RegTotal = Regtotal + ST4MRA
