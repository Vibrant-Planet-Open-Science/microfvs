{
    "name": "microfvs Dev Container",
    "build": {
        "dockerfile": "Dockerfile",
        "context": ".."
    },
    "remoteEnv": {
        "PYTHONPATH": "/code/microfvs"
    },
    "containerEnv": {
        "PYTHONPATH": "/code/microfvs"
    },
    "features": {
        "ghcr.io/devcontainers/features/common-utils": {
            "installZsh": true,
            "installOhMyZsh": true,
            "installOhMyZshConfig": true,
            "configureZshAsDefaultShell": true
        },
        "ghcr.io/prulloac/devcontainer-features/pre-commit:latest": {},
        "ghcr.io/devcontainers-extra/features/apt-packages:1": {
            "packages": "nano"
        }
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "charliermarsh.ruff",
                "github.vscode-github-actions",
                "github.vscode-pull-request-github",
                "johnpapa.vscode-peacock",
                "ms-azuretools.vscode-docker",
                "ms-python.black-formatter",
                "ms-python.isort",
                "ms-python.mypy-type-checker",
                "ms-python.python",
                "ms-toolsai.jupyter-keymap",
                "ms-toolsai.jupyter-renderers",
                "ms-toolsai.jupyter",
                "vscode-icons-team.vscode-icons"
            ],
            "settings": {
                "mypy-type-checker.args": [
                    "--config-file",
                    "mypy.ini"
                ],
                "notebook.formatOnSave.enabled": true,
                "python.defaultInterpreterPath": "/usr/local/bin/python3",
                "python.analysis.extraPaths": [
                    "/code/microfvs"
                ],
                "python.linting.mypyEnabled": true,
                "python.linting.enabled": true,
                "[python]": {
                    "editor.formatOnSave": true,
                    "editor.defaultFormatter": "charliermarsh.ruff",
                    "editor.codeActionsOnSave": {
                        "source.fixAll": "explicit",
                        "source.organizeImports": "explicit"
                    },
                    "terminal.integrated.env.linux": {
                        "PYTHONPATH": "/code/microfvs"
                    }
                }
            }
        }
    },
    "runArgs": [
        "--name",
        "microfvs-dev"
    ],
    "mounts": [
        "source=${localEnv:HOME}/.zshrc,target=/home/microfvs-dev/.zshrc,type=bind",
        "source=${localEnv:HOME}/.oh-my-zsh,target=/home/microfvs-dev/.oh-my-zsh,type=bind"
    ],
    "postCreateCommand": "pip install pre-commit ipykernel -r requirements-dev.txt && pre-commit install",
    "postStartCommand": "git config --global core.trustctime false && git config --global core.checkStat minimal",
    "workspaceMount": "source=${localEnv:HOME}/projects/microfvs,target=/code/microfvs,type=bind",
    "workspaceFolder": "/code/microfvs"
}